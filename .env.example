# =============================================================================
# DriveMaster Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Cron / Admin (required for leaderboard processing)
CRON_SECRET=generate-a-random-secret-here
ADMIN_API_KEY=generate-a-random-key-here

# Monitoring (optional but recommended)
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# Feature Flags (Phase 2-3 — all default OFF)
NEXT_PUBLIC_FEATURE_SHARING=false
NEXT_PUBLIC_FEATURE_CHALLENGES=false
NEXT_PUBLIC_FEATURE_COUNTDOWN=false
NEXT_PUBLIC_FEATURE_AI_EXPLANATIONS=false
NEXT_PUBLIC_FEATURE_PARENT_NOTIFICATIONS=false
NEXT_PUBLIC_FEATURE_I18N=false

# AI Explanations (Phase 2 — only needed when feature flag is ON)
SYNTHETIC_API_KEY=

# Email (Phase 3 — only needed when parent notifications flag is ON)
RESEND_API_KEY=
